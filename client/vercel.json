{
  "rewrites": [
    {
      "source": "/api/v1/compute/static/:path*",
      "destination": "https://us.i.posthog.com/static/:path*"
    },
    {
      "source": "/api/v1/compute/:path*",
      "destination": "https://us.i.posthog.com/:path*"
    },
    {
      "source": "/api/v1/compute/decide/:path*",
      "destination": "https://us.i.posthog.com/decide/:path*"
    },
    {
      "source": "/((?!api/v1/compute|api|static|favicon.ico|_next).*)",
      "destination": "/index.html"
    }
  ]
}



